{
  "expo": {
    "name": "笑顔チェッカー",
    "slug": "smile-checker",
    "scheme": "smilechecker",
    "version": "0.1.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nashiko.smilechecker",
      "infoPlist": {
        "NSCameraUsageDescription": "笑顔を検出するためにカメラを使用します。",
        "NSUserTrackingUsageDescription": "パーソナライズされた広告を表示するために使用します。",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.nashiko.smilechecker",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "assetBundlePatterns": [
      "assets/**/*"
    ],
    "plugins": [
      "expo-router",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "笑顔を検出するためにカメラを使用します。",
          "enableMicrophonePermission": false,
          "enableCodeScanner": false
        }
      ],
      [
        "react-native-fast-tflite",
        {
          "enableCoreMLDelegate": false,
          "enableAndroidGpuLibraries": false
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          },
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      "expo-asset",
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "パーソナライズされた広告を表示するために使用します。"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "iosAppId": "ca-app-pub-6109118020281273~2694382068"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "e6ba2093-8e6e-430b-abc9-4584d8126d88"
      }
    },
    "owner": "nashiko"
  }
}
